{
  "name": "qrcodeorganizer",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "lint": "expo lint",
    "testDebug": "jest -o --watch --coverage=false",
    "testFinal": "jest",
    "updateSnapshots": "jest -u --coverage=false",
    "deploy": "bash scripts/build-and-deploy.sh all",
    "deploy:ios": "bash scripts/build-and-deploy.sh ios",
    "deploy:android": "bash scripts/build-and-deploy.sh android",
    "build:ios": "bash scripts/build-and-deploy.sh ios --skip-submit",
    "build:android": "bash scripts/build-and-deploy.sh android --skip-submit"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "<rootDir>/__tests__/test-setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg)"
    ],
    "moduleNameMapper": {
      "^~/(.*)$": "<rootDir>/$1"
    },
    "testPathIgnorePatterns": [
      "<rootDir>/node_modules/",
      "<rootDir>/__tests__/test-setup.js",
      "<rootDir>/__tests__/Index-test.tsx"
    ],
    "collectCoverage": true,
    "collectCoverageFrom": [
      "**/*.{ts,tsx,js,jsx}",
      "!**/.agents/**",
      "!**/.claude/**",
      "!**/coverage/**",
      "!**/node_modules/**",
      "!**/babel.config.js",
      "!**/expo-env.d.ts",
      "!**/.expo/**"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-picker/picker": "2.11.4",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "babel-plugin-inline-import": "^3.0.0",
    "drizzle-orm": "^0.43.1",
    "expo": "^55.0.9",
    "expo-blur": "~55.0.10",
    "expo-camera": "~55.0.11",
    "expo-clipboard": "~55.0.9",
    "expo-constants": "~55.0.9",
    "expo-document-picker": "~55.0.9",
    "expo-drizzle-studio-plugin": "^0.2.1",
    "expo-file-system": "~55.0.12",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.9",
    "expo-linking": "~55.0.9",
    "expo-localization": "~55.0.9",
    "expo-router": "~55.0.8",
    "expo-sharing": "~55.0.14",
    "expo-splash-screen": "~55.0.13",
    "expo-sqlite": "~55.0.11",
    "expo-status-bar": "~55.0.4",
    "expo-store-review": "~55.0.9",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.11",
    "expo-web-browser": "~55.0.10",
    "i18next": "^25.0.2",
    "nativewind": "^4.1.23",
    "papaparse": "^5.5.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^15.5.1",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-qrcode-svg": "^6.3.15",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.2",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.12",
    "@types/papaparse": "^5.3.15",
    "@types/react": "~19.2.10",
    "@types/react-test-renderer": "^19.0.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "drizzle-kit": "^0.31.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~55.0.0",
    "jest": "^29.2.1",
    "jest-expo": "~55.0.11",
    "react-test-renderer": "19.2.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
