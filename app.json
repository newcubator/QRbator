{
  "expo": {
    "name": "QRbator",
    "slug": "qrbator",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "qrbator",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "de.newcubator.QRbator",
      "buildNumber": "4",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "appleTeamId": "8AF5S7C42H",
      "appStoreUrl": "https://apps.apple.com/app/6745259686"
    },
    "android": {
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "de.newcubator.QRbator",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "playStoreUrl": "https://play.google.com/store/apps/details?id=de.newcubator.QRbator"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "dark": {
            "image": "./assets/images/splash-icon-dark.png",
            "backgroundColor": "#F3F3F3"
          },
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F3F3F3"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera and scan QR codes"
        }
      ],
      "expo-sqlite",
      "expo-font",
      "expo-web-browser",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "00d62b28-a0f2-41fa-97bb-6f4544a08ae3"
      }
    },
    "owner": "dennishundertmark"
  }
}
